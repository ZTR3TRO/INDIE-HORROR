{
  "name": "indie-horror-game",
  "version": "1.0.0",
  "description": "Juego de terror indie en 3D low-poly",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.zada.nightfall",
    "productName": "NIGHTFALL",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/images/zada.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/images/zada.png"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
